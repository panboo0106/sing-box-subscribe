        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/anthropic.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-google-gemini",
        "type": "remote",
