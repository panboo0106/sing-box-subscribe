{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://gh-proxy.com/https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip",
      "external_ui_download_detour": "direct",
      "default_mode": "rule"
    },
    "cache_file": {
      "enabled": true,
      "store_fakeip": false,
      "store_rdrc": true
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "remote",
        "type": "tls",
        "server": "8.8.8.8",
        "detour": "Proxy"
      },
      {
        "tag": "local",
        "type": "https",
        "server": "223.5.5.5"
      },
      {
        "tag": "tailscale-dns",
        "type": "tailscale",
        "endpoint": "ts",
        "accept_default_resolvers": false
      }
    ],
    "rules": [
      {
        "clash_mode": "direct",
        "action": "route",
        "server": "local"
      },
      {
        "clash_mode": "global",
        "action": "route",
        "server": "remote"
      },
      {
        "domain_suffix": [
          ".arpa",
          ".local"
        ],
        "action": "route",
        "server": "local"
      },
      {
        "domain_suffix": [
          ".ts.net",
          ".tailscale.net"
        ],
        "action": "route",
        "server": "tailscale-dns"
      },
      {
        "domain_suffix": [
          ".tailscale.com",
          ".tailscale.io"
        ],
        "action": "route",
        "server": "local"
      },
      {
        "domain": [
          "gemini.google.com",
          "generativelanguage.googleapis.com",
          "aiplatform.googleapis.com",
          "makersuite.google.com",
          "aistudio.google.com",
          "alkalimakersuite-pa.clients6.google.com",
          "alkalicore-pa.clients6.google.com",
          "openai.com",
          "chat.openai.com",
          "api.openai.com",
          "platform.openai.com",
          "auth.openai.com",
          "cdn.openai.com",
          "files.oaiusercontent.com",
          "claude.ai",
          "api.claude.ai",
          "anthropic.com",
          "api.anthropic.com",
          "console.anthropic.com",
          "perplexity.ai",
          "copilot.microsoft.com",
          "sydney.bing.com",
          "chat.deepseek.com",
          "api.deepseek.com",
          "gateway.ai.cloudflare.com"
        ],
        "action": "route",
        "server": "remote"
      },
      {
        "rule_set": [
          "geosite-openai",
          "geosite-anthropic",
          "geosite-google-gemini",
          "geosite-perplexity",
          "geosite-copilot"
        ],
        "action": "route",
        "server": "remote"
      },
      {
        "rule_set": "geosite-cn",
        "action": "route",
        "server": "local"
      }
    ],
    "final": "remote",
    "independent_cache": true
  },
  "inbounds": [
    {
      "tag": "mixed-in",
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "tag": "Proxy",
      "type": "selector",
      "outbounds": [
        "auto",
        "AI",
        "Global",
        "HK",
        "TW",
        "SG",
        "JP",
        "US",
        "Others",
        "direct",
        "{all}"
      ]
    },
    {
      "tag": "AI",
      "type": "selector",
      "outbounds": [
        "SelfBuild",
        "SelfBuildAuto",
        "US",
        "JP",
        "SG",
        "direct"
      ],
      "default": "SelfBuild"
    },
    {
      "tag": "SelfBuildAuto",
      "type": "urltest",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "自建|selfbuild|🏠"
          ]
        }
      ],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "tag": "Global",
      "type": "selector",
      "outbounds": [
        "SelfBuild",
        "HK",
        "TW",
        "SG",
        "JP",
        "US",
        "Others",
        "auto"
      ]
    },
    {
      "tag": "SelfBuild",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "自建|selfbuild|🏠"
          ]
        }
      ]
    },
    {
      "tag": "HK",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "香港|Hong Kong|HK|🇭🇰"
          ]
        }
      ]
    },
    {
      "tag": "TW",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "台湾|台灣|Taiwan|TW|🇹🇼"
          ]
        }
      ]
    },
    {
      "tag": "SG",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "新加坡|Singapore|SG|🇸🇬"
          ]
        }
      ]
    },
    {
      "tag": "JP",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "日本|Japan|JP|🇯🇵"
          ]
        }
      ]
    },
    {
      "tag": "US",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "美国|美國|United States|US|USA|America|🇺🇸"
          ]
        }
      ]
    },
    {
      "tag": "Others",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "exclude",
          "keywords": [
            "香港|Hong Kong|HK|🇭🇰|台湾|台灣|Taiwan|TW|🇹🇼|新加坡|Singapore|SG|🇸🇬|日本|Japan|JP|🇯🇵|美国|美國|United States|US|USA|America|🇺🇸|自建|selfbuild|🏠"
          ]
        }
      ]
    },
    {
      "tag": "auto",
      "type": "urltest",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "exclude",
          "keywords": [
            "网站|地址|剩余|过期|时间|有效"
          ]
        }
      ],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "tag": "direct",
      "type": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "Proxy",
    "default_domain_resolver": {
      "server": "local"
    },
    "rules": [
      {
        "inbound": [
          "mixed-in"
        ],
        "action": "sniff"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "rule_set": "geosite-category-ads-all",
        "action": "reject"
      },
      {
        "clash_mode": "direct",
        "action": "route",
        "outbound": "direct"
      },
      {
        "clash_mode": "global",
        "action": "route",
        "outbound": "Global"
      },
      {
        "domain": [
          "clash.razord.top",
          "yacd.metacubex.one",
          "yacd.haishan.me",
          "d.metacubex.one",
          "metacubexd.pages.dev"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_cidr": [
          "100.64.0.0/10",
          "fd7a:115c:a1e0::/48"
        ],
        "action": "route",
        "outbound": "ts"
      },
      {
        "domain_suffix": [
          ".ts.net",
          ".tailscale.net"
        ],
        "action": "route",
        "outbound": "ts"
      },
      {
        "domain_suffix": [
          ".tailscale.com",
          ".tailscale.io"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "domain": [
          "gemini.google.com",
          "generativelanguage.googleapis.com",
          "aiplatform.googleapis.com",
          "makersuite.google.com",
          "aistudio.google.com",
          "alkalicore-pa.clients6.google.com",
          "alkalimakersuite-pa.clients6.google.com",
          "gateway.ai.cloudflare.com",
          "openai.com",
          "chat.openai.com",
          "api.openai.com",
          "platform.openai.com",
          "cdn.openai.com",
          "auth.openai.com",
          "files.oaiusercontent.com",
          "claude.ai",
          "api.claude.ai",
          "anthropic.com",
          "api.anthropic.com",
          "console.anthropic.com",
          "perplexity.ai",
          "copilot.microsoft.com",
          "sydney.bing.com",
          "chat.deepseek.com",
          "api.deepseek.com"
        ],
        "action": "route",
        "outbound": "AI"
      },
      {
        "rule_set": [
          "geosite-openai",
          "geosite-anthropic",
          "geosite-google-gemini",
          "geosite-perplexity",
          "geosite-copilot"
        ],
        "action": "route",
        "outbound": "AI"
      },
      {
        "rule_set": [
          "geoip-cn",
          "geosite-cn"
        ],
        "action": "route",
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "tag": "geosite-category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/category-ads-all.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-openai",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/openai.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-anthropic",
